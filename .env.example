TELEGRAM_BOT_TOKEN=123456:replace-me
OPENAI_API_KEY=replace-me
ASSISTANT_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
# required for startup; restrict the bot to your own chats
# TELEGRAM_ALLOWED_CHAT_IDS=123456789
# TELEGRAM_PUSH_CHAT_IDS=123456789
# Public repo note:
# - keep real secrets only in a local .env file
# - never commit real tokens, chat ids, cookies or personal memory data
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_REQUEST_TIMEOUT_SECONDS=60
TELEGRAM_DROP_PENDING_UPDATES=true
LANGSMITH_TRACING=false
DIGEST_ENABLED=true
DIGEST_RUN_ON_STARTUP=false
DIGEST_SCHEDULE_HOUR=9
DIGEST_TIMEZONE=Asia/Shanghai
